# ─────────────────────────────────────────────────────────────────
# SimplyGersi Dashboard — Environment Variables
# Copy this file to .env.local and fill in all values.
# ─────────────────────────────────────────────────────────────────

# Notion Integration Secret
# Get from: notion.so/my-integrations → your integration → Secrets
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TIER 1: Core databases (required for full dashboard) ─────────
# Get each ID from the Notion URL: notion.so/workspace/[THIS-32-CHAR-ID]?v=...
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DEALS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_INVOICES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAYMENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_GOALS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTENT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TIER 2: Strongly recommended ─────────────────────────────────
NOTION_NOTES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RESOURCES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_THREAD_REVIEWS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Quick Link URLs (paste full Notion page/database URLs) ────────
# These appear as buttons in the Quick Links panel.
NEXT_PUBLIC_LINK_COMMAND_CENTER=https://notion.so/your-command-center-page-id
NEXT_PUBLIC_LINK_HUB=https://notion.so/your-simplygersi-hub-page-id
NEXT_PUBLIC_LINK_DEAL_HUB=https://notion.so/your-deal-hub-database-id
NEXT_PUBLIC_LINK_TASKS=https://notion.so/your-tasks-database-id
NEXT_PUBLIC_LINK_CONTENT_HUB=https://notion.so/your-content-hub-database-id
NEXT_PUBLIC_LINK_NOTES=https://notion.so/your-notes-database-id
NEXT_PUBLIC_LINK_RESOURCES=https://notion.so/your-resources-database-id
NEXT_PUBLIC_LINK_INVOICES=https://notion.so/your-invoices-database-id

# ── Phase 2 (not built yet — Brand Outreach) ─────────────────────
# NOTION_OUTREACH_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
